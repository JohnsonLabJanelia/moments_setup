# =============================================================================
# config.env — single source of truth for the moments install scripts.
# Sourced by every step. Override any value via the environment, e.g.:
#   ARTIFACTS_DIR=/media/usb/moments_artifacts ./install_phase1.sh
# =============================================================================

# --- Where the USB payload lives (the moments_artifacts folder) --------------
# Default assumes the artifacts sit next to this repo; on the new machine this
# will usually be your mounted USB drive — override ARTIFACTS_DIR accordingly.
: "${ARTIFACTS_DIR:=$(cd "${INSTALL_DIR:-$(dirname "${BASH_SOURCE[0]}")}/../../moments_artifacts" 2>/dev/null && pwd || echo /media/$USER/moments_artifacts)}"

# --- Target OS (autodetected; must be 22.04 or 24.04) ------------------------
: "${OS_VERSION:=$(. /etc/os-release 2>/dev/null && echo "${VERSION_ID:-22.04}")}"
OS_TAG="Ubuntu_${OS_VERSION/./_}"        # -> Ubuntu_22_04 / Ubuntu_24_04

# --- Pinned versions (must match the reference machine / payload) ------------
DRIVER_VERSION="535.183.06"
CUDA_VERSION="12.2"
ESDK_VERSION="4.07.01"
RIVERMAX_VERSION="1.70.32"
DOCA_VERSION="3.0.0"
TENSORRT_VERSION="8.6.1.6"
CUDNN8_VERSION="8.9.3.28"

# --- Install destinations (CMake hardcodes $HOME/nvidia/* — do not relocate) -
NVIDIA_PREFIX="$HOME/nvidia"             # ffmpeg + TensorRT live here
SRC_PREFIX="${SRC_PREFIX:-$HOME/src}"    # orange/red source extracted here
ORANGE_DATA_DIR="$HOME/orange_data"      # runtime camera config presets

# --- Artifact paths (relative to ARTIFACTS_DIR) ------------------------------
A_DRIVER_RUN="$ARTIFACTS_DIR/10_nvidia/NVIDIA-Linux-x86_64-${DRIVER_VERSION}.run"
A_CUDA_RUN="$ARTIFACTS_DIR/10_nvidia/cuda_12.2.2_535.104.05_linux.run"
A_NOUVEAU_CONF="$ARTIFACTS_DIR/10_nvidia/evt-disable-nouveau.conf"
A_DOCA_DEB="$ARTIFACTS_DIR/20_ofed_rivermax/doca-host_3.0.0-058000-25.04-ubuntu2204_amd64.deb"
A_RIVERMAX_DEB="$ARTIFACTS_DIR/20_ofed_rivermax/rivermax_ubuntu2204_${RIVERMAX_VERSION}_amd64.deb"
A_RIVERMAX_LIC="$ARTIFACTS_DIR/20_ofed_rivermax/rivermax.lic"
A_ESDK_ZIP="$ARTIFACTS_DIR/30_emergent/eSDK_4_07_01_eCap_2_14_02_${OS_TAG}_6_8_0_x64.zip"
A_FFMPEG_TAR="$ARTIFACTS_DIR/40_ffmpeg/nvidia-ffmpeg-n4.4.5-cuda-prebuilt.tar.zst"
A_ORANGE_TAR="$ARTIFACTS_DIR/50_source/orange-rob_minimal.tar.zst"
A_ORANGE_DATA="$ARTIFACTS_DIR/orange_data"
A_TRT_TAR="$ARTIFACTS_DIR/phase2_red/TensorRT-${TENSORRT_VERSION}.tar.zst"
A_CUDNN8_TAR="$ARTIFACTS_DIR/phase2_red/cudnn-linux-x86_64-${CUDNN8_VERSION}_cuda12-archive.tar.xz"
A_RED_TAR="$ARTIFACTS_DIR/phase2_red/red-xp.tar.zst"

# --- Behaviour ---------------------------------------------------------------
: "${MOMENTS_ASSUME_YES:=0}"             # set 1 to skip confirmation prompts
: "${MOMENTS_STATE_DIR:=$HOME/.moments-setup/state}"
: "${MOMENTS_LOG_DIR:=$HOME/.moments-setup/logs}"
